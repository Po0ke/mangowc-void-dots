#!/bin/bash

# 1. Check if a directory was provided
if [ -z "$1" ]; then
    echo "Usage: wallpaper-set /path/to/directory"
    exit 1
fi

WALLPAPER_DIR="$1"

# 2. Pick a random image file
SELECTED_WALL=$(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" -o -iname "*.webp" \) | shuf -n 1)

# 3. Check if an image was found
if [ -z "$SELECTED_WALL" ]; then
    echo "No images found in $WALLPAPER_DIR"
    exit 1
fi

# 4. Set the wallpaper with swww
swww img "$SELECTED_WALL" --transition-type grow --transition-pos center --transition-fps 75 --transition-step 90 --transition-duration 2

# 5. Generate and apply color palette with pywal
# -i specifies the image; -n skips setting the wallpaper via wal (since swww handles it)
wal -i "$SELECTED_WALL" && .config/mango/change-theme

echo "THEME SELECTED SUCCESSFULLY"
